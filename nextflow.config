// ============================================================
// nextflow.config — Sorghum assembly pipeline
// Default: local; use -profile condor for HTCondor execution
// ============================================================

manifest {
    name            = 'sorghum-assembly'
    description     = 'ONT-based sorghum genome assembly with organelle separation'
    version         = '0.1.0'
    nextflowVersion = '>=24.04.0'
}

// ---- Default params ----
params {
    reads        = "${projectDir}/reads"
    cp_ref       = null
    mt_ref       = null
    
    organelle_assembler = "flye"        // "flye" or "oatk"
    filter_organelles   = true          // apply reference-based filter post-assembly
    organelle_min_qcov  = 0.5           // min fraction of contig covered by ref alignment
    organelle_min_ident = 0.7           // min identity (matches / alignment_length)
    
    nuclear_ref  = null
    outdir       = "results"
    genome_size  = "780m"
    
    busco_lineage = "poales_odb10"
    medaka_model = "r1041_e82_400bps_sup_v5.2.0"
    
    run_hapdup   = false
    help         = false

    ragtag_correct = true    // ragtag.py correct reduces misassemblies 2398→2309 vs. skipping
    calcuts_args   = ""      // empty = autotune peak from PB.stat; or e.g. "-l 5 -m 22 -u 120"
    // purge_dups ALWAYS runs; both the Medaka and purged genomes are scaffolded, QUAST'd and
    // BUSCO'd for comparison. final_assembly selects which becomes THE published genome (gets
    // Qualimap/BlobTools/Kraken2 + FINAL_SUMMARY). 'medaka' (default) = unpurged; 'purge' = purged.
    final_assembly = 'medaka'   // medaka | purge
    skip_purge     = null       // RETIRED: if set, main.nf errors pointing to --final_assembly
    run_qualimap   = false   // BAM-level QC via Qualimap bamqc (purge + scaffold stages)
    run_blobtools  = false   // GC-vs-coverage blob plots via BlobTools (coverage-only, no taxonomy DB)

    // Contaminant screening: Kraken2 classifies each contig, then BlobTools renders the
    // coverage-vs-GC blob plot coloured by taxonomy. Off by default (needs the big DB below).
    run_kraken2    = false
    // PlusPF Kraken2 DB (104 GB hash.k2d: bacteria/archaea/viral/human/protozoa/fungi/
    // plasmid/UniVec). Small enough to load fully into the qc_heavy RAM allocation, so
    // KRAKEN2_CLASSIFY runs WITHOUT --memory-mapping (one sequential load, then fast).
    // The 456 GB PRAKEN reference DB was abandoned: it exceeds node RAM, forcing
    // --memory-mapping, whose per-k-mer random reads over cephfs never finished.
    kraken2_db     = '/mnt/cephfs/linuxhome/compbio/nonbackup/databases/PlusPF'
    // BlobTools resolves Kraken2 taxids → lineage from the DB's own taxdump (nodes.dmp +
    // names.dmp ship inside PlusPF), keeping classifier and taxonomy the same vintage.
    taxdump_dir    = '/mnt/cephfs/linuxhome/compbio/nonbackup/databases/PlusPF'
}

// ---- Apptainer (containers) ----
apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = "${System.getenv('HOME')}/.apptainer_cache"
    pullTimeout = '60m'
}

// ---- Default process settings & resource labels ----
process {
    // safe defaults
    cpus   = 8
    memory = '32 GB'
    time   = '4h'
    errorStrategy = { task.exitStatus in [132, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 2
    clusterOptions = 'requirements = Machine != "scarcity-14.glbrc.org"'

    // resource classes (used by per-process labels)
    withLabel: 'qc' {
        cpus   = 16
        memory = '128 GB'
        time   = '12h'
    }
    withLabel: 'qc_heavy' {
        cpus   = 16
        memory = '128 GB'
        time   = '24h'
    }
    withLabel: 'map' {
        cpus   = 24
        memory = '128 GB'
        time   = '12h'
    }
    withLabel: 'assemble_small' {
        cpus   = 16
        memory = '128 GB'
        time   = '6h'
    }
    withLabel: 'assemble_heavy' {
        cpus   = 32
        memory = '448 GB'
        time   = '120h'
        clusterOptions = 'requirements = (' +
            'Machine == "scarcity-1.glbrc.org" || ' +
            'Machine == "scarcity-2.glbrc.org" || ' +
            'Machine == "scarcity-3.glbrc.org" || ' +
            'Machine == "scarcity-4.glbrc.org" || ' +
            'Machine == "scarcity-5.glbrc.org" || ' +
            'Machine == "scarcity-9.glbrc.org" || ' +
            'Machine == "scarcity-11.glbrc.org" || ' +
            'Machine == "scarcity-12.glbrc.org" || ' +
            'Machine == "scarcity-13.glbrc.org" || ' +
            'Machine == "scarcity-20.glbrc.org")'
    }
    withLabel: 'polish' {
        cpus   = 24
        memory = '256 GB'
        time   = '48h'
        // medaka's torch/ONNX binary SIGILLs (exit 132) on scarcity-9's CPU —
        // keep polishing off it (and the default-bad scarcity-14).
        clusterOptions = 'requirements = (Machine != "scarcity-9.glbrc.org" && Machine != "scarcity-14.glbrc.org")'
    }
    // KRAKEN2_CLASSIFY loads the 104 GB PlusPF DB fully into RAM (no --memory-mapping),
    // so it needs more than the 128 GB qc_heavy label. withName outranks withLabel, so
    // this is the override that actually takes effect (a process-body `memory` directive
    // would be shadowed by the label). 160 GB leaves headroom for taxo.k2d + overhead.
    withName: 'KRAKEN2_CLASSIFY' {
        memory = '160 GB'
    }
}

// ---- Execution profiles ----
profiles {

    standard {
        process.executor = 'local'
    }

    condor {
        process {
            executor = 'condor'
            // HTCondor-specific options can be added per-process via clusterOptions
        }
        executor {
            queueSize       = 50      // max concurrent jobs
            submitRateLimit = '10/1min'
        }
    }

    debug {
        process.beforeScript = 'echo "RUNNING: $HOSTNAME @ $(date)"'
    }
}

// ---- Email notification on pipeline completion ----
notification {
    enabled = true
    to      = 'gian.benucci@gmail.com'
}

// ---- Reporting ----
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,name,status,exit,realtime,cpus,memory,rss,peak_rss,duration'
}

dag {
    enabled   = true
    file      = "${params.outdir}/dag.html"
    overwrite = true
}

// ---- workDir: point to scratch on HPC ----
// Override on the CLI with: -w /scratch/$USER/nf-work
workDir = "${System.getenv('HOME')}/nf-work-sorghum"
